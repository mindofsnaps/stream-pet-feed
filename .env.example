# =============================================================================
# stream-pet-feed — environment variables
#
# Copy this file to .env.local for local development, OR paste these into your
# host's environment settings (e.g. Vercel > Project > Settings > Environment
# Variables) for production. NEVER commit your real .env.local.
# =============================================================================

# --- REQUIRED: Supabase (your database + photo storage) ----------------------
# From your Supabase project: Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# The service_role secret — NOT the anon key. Keep it secret (server-only).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# --- REQUIRED: secrets -------------------------------------------------------
# Signs the login cookies. Use a long random string (>= 32 chars). Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string-min-32-chars
# Password you'll type to reach the moderation queue (/admin/login).
ADMIN_PASSWORD=pick-a-strong-admin-password
# Optional: the name stamped on approvals in the queue. Defaults to "admin".
# ADMIN_NAME=yourname

# --- How viewers submit ------------------------------------------------------
# "twitch": viewers sign in with Twitch and declare which currency they spent
#           (gifted sub / bits / points), which you confirm in the queue.
# "none":   no login — anyone can submit; the approval queue is the only gate.
PETFEED_LOGIN_MODE=twitch

# --- REQUIRED ONLY IF PETFEED_LOGIN_MODE=twitch ------------------------------
# Create a Twitch application at https://dev.twitch.tv/console/apps with the
# OAuth Redirect URL set to:  <APP_PUBLIC_URL>/api/auth/twitch-callback
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret
# The full public URL of THIS app (no trailing slash). Locally: http://localhost:3000
APP_PUBLIC_URL=https://your-app.vercel.app

# --- OPTIONAL: tuning (all have sensible defaults) ---------------------------
# Your channel name, used in on-page copy. Defaults to "the stream".
PETFEED_CHANNEL_NAME=the stream
# Also shows your channel in the browser tab title (public, so NEXT_PUBLIC_).
NEXT_PUBLIC_CHANNEL_NAME=the stream
# Twitch-mode unlock thresholds (display copy; you confirm spends in the queue).
PETFEED_GIFTED_SUBS=1
PETFEED_BITS=2500
PETFEED_POINTS=250000
# Max submissions of the SAME pet per rolling 30 days.
PETFEED_MAX_PER_PET_30D=5
# Overlay rotation: seconds per photo, and crossfade length in ms.
PETFEED_ROTATE_SECONDS=8
PETFEED_CROSSFADE_MS=1200
